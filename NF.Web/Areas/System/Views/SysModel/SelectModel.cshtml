
@{
    ViewData["Title"] = "SelectModel";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style type="text/css">

    form {
        width: 500px;
        margin: 10px auto;
    }

    h1, h2, h3 {
        padding: 10px 0;
    }

    a {
        text-align: right;
        font-size: 18px;
        color: #1C86EE;
    }

    .xtree_contianer {
        width: 450px;
        border: 1px solid #9C9C9C;
        overflow: auto;
        margin-bottom: 30px;
        background-color: #fff;
        padding: 10px 0 25px 5px;
    }

    .div-btns {
        margin: 20px 0;
    }

    .layui-form-label {
        width: 60px !important;
    }
</style>

<div class="layui-fluid">
    <!--用户基本信息begin-->
    <div class="layui-form" lay-filter="Nf-SystemAdmin-RoleForm">
        <input type="hidden" id="Id" name="Id" />
        <input type="hidden" id="setType" name="setType" />
        <input type="hidden"  id="ckNodeIds" name="ckNodeIds" />
        <div class="layui-card ">
            <div class="layui-card-header">请选择菜单信息</div>
            <div class="layui-card-body" style="padding: 15px;">
                <div id="xtree_sysmodel" class="xtree_contianer"></div>



                <!--需要在最后加这个或者没有也加一个 <div class="layui-form-item">，这样不会导致隐藏菜单是显示问题-->
                <div class="layui-form-item">

                </div>

            </div>
        </div>


        <!--按钮begin-->
        <div class="layui-form-item layui-layout-admin layui-hide">
            <div class="layui-input-block">
                <div class="layui-footer" style="left: 0;">
                    <button class="layui-btn" id="Nf-SystemAdmin-RoleModelSubmit" lay-submit lay-filter="Nf-SystemAdmin-RoleModelSubmit">保存</button>
                    <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                </div>
            </div>
        </div>
        <!--按钮begin-->
    </div>
    <!--用户基本信息end-->

</div>

@{
    Html.RenderPartial("_LayuiScriptsPartial");
}
<script src="~/lib/layui-xtree/layui-xtree.js" type="text/javascript"></script>
<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index' //主入口模块
    }).use(['index', 'form'], function () {
        var $ = layui.$
            , admin = layui.admin
            , element = layui.element
            , layer = layui.layer
            , form = layui.form;
       
        var byId = wooutil.getUrlVar('Id');//设置对象ID
        var setType = wooutil.getUrlVar('setType');//设置类型1：角色，2：用户
       
        $("#Id").val(byId);
        $("#setType").val(setType);
        var xtree_sysmodel = new layuiXtree({
            elem: 'xtree_sysmodel'
            , form: form
            , data: '/System/SysModel/GetSelectTreeData?roleId=' + byId + "&setType=" + setType+ "&rand="+ wooutil.getRandom()
            //, isopen: false  //加载完毕后的展开状态，默认值：true
            , ckall: true    //启用全选功能，默认值：false
            , ckallback: function () {

            } //全选框状态改变后执行的回调函数
            , icon: { //三种图标样式，更改几个都可以，用的是layui的图标
                open: "&#xe7a0;"       //节点打开的图标
                , close: "&#xe622;"    //节点关闭的图标
                , end: "&#xe621;"      //末尾节点的图标
            }
            , color: {       //三种图标颜色，独立配色，更改几个都可以
                open: "#EE9A00"        //节点图标打开的颜色
                , close: "#EEC591"     //节点图标关闭的颜色
                , end: "#828282"       //末级节点图标的颜色
            }
            , click: function (data) {  //节点选中状态改变事件监听，全选框有自己的监听事件

                console.log(data.elem); //得到checkbox原始DOM对象
                console.log(data.elem.checked); //开关是否开启，true或者false
                console.log(data.value); //开关value值，也可以通过data.elem.value得到
                console.log(data.othis); //得到美化后的DOM对象

            }
        });
        //获取选中节点
        $("#Nf-SystemAdmin-RoleModelSubmit").click(function () {
           // var arr1 = xtree_sysmodel.GetChecked();
            var cknodes = [];
            var nodeall = xtree_sysmodel.GetAllCheckBox();           
            for (var i = 0; i < nodeall.length; i++) {
                if (nodeall[i].checked && (nodeall[i].title !== "全选" && nodeall[i].title !== "系统菜单"))
                {
                    cknodes.push(nodeall[i].value);
                }

            }
            $("#ckNodeIds").val(cknodes.toString());
           
        });
        //--------------------------修改的时候赋值----------------------------------
        //if (byId != "" && byId != undefined) {
        //    admin.req({
        //        url: '/System/Role/ShowView',
        //        data: { Id: byId, rand: wooutil.getRandom() },
        //        done: function (res) {
        //            //layer.alert(JSON.stringify(res.Data));
        //            form.val("Nf-SystemAdmin-RoleForm", res.Data);

        //        }
        //    });

        //}
        //-------------------------------------修改赋值end--------------------------------------------
        //form.render(null, 'Nf-SystemAdmin-RoleForm');

    });
</script>

