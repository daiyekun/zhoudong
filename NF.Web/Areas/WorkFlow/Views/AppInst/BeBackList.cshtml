
@{
    ViewData["Title"] = "被打回列表";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="layui-fluid">
    <input type="hidden" name="hide_keyWord" />
    <div class="layui-card">
        <div class="layui-card-body">
            <table id="NF-BeBackList" lay-filter="NF-BeBackList"></table>

            <script type="text/html" id="viewTpl">
                <a class="layui-table-link hand" lay-text="查看详情" lay-event="backView">
                    <cite>{{d.AppObjName}}</cite>
                </a>
            </script>
            <!--表格工具栏-->
            <script id="toolappBeBack" type="text/html">
                <div class="layui-inline">
                    <input class="layui-input" type="text" name="keyWord" placeholder="名称、编号" style="width:240px;" />

                </div>
                <div class="layui-inline">
                    <button class="layui-btn" lay-event="search">
                        <i class="layui-icon layui-icon-search layuiadmin-button-btn"></i>
                    </button>
                </div>
            </script>

            <script type="text/html" id="wf-back-bar">
                <a class="layui-btn layui-btn-normal layui-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i>修改</a>
                <a class="layui-btn  layui-btn-xs" lay-event="view"><i class="layui-icon layui-icon-tips"></i>查看</a>
            </script>

        </div>
    </div>
</div>


@{
    Html.RenderPartial("_LayuiScriptsPartial");
}

<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index', //主入口模块
        beBackList: 'workflow-nf/bebacklist'
        , flowEventHandler: 'workflow-nf/utility/flowEventHandler'

    }).use(['index', 'beBackList'], function () {

     });
</script>

