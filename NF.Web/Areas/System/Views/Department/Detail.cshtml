        @{
            Html.RenderPartial("_LayuiScriptsPartial");
        }
        <script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index',
        // nfcontents:'contents-nf/nfcontents'
        systemDepartDetail: 'system-nf/nf-system-departmentdetail'
        }).use(['index', 'form', 'laydate', 'systemDepartDetail'], function () {
            var $ = layui.$
                , admin = layui.admin
                , element = layui.element
                , layer = layui.layer
               // , laydate = layui.laydate
               // , treeselect = layui.treeselect
                , table = layui.table
                , form = layui.form;
           // , nfcontents = layui.nfcontents;
        var byId = wooutil.getUrlVar('Id');

            //--------------------------修改的时候赋值----------------------------------

            if (byId != "" && byId != undefined)
            {
            admin.req({
                url: '/System/Department/ShowView',
                data: { Id: byId },
                done: function (res)
                {
                    //layer.alert(JSON.stringify(res.Data));
                    form.val("Nf-SystemAdmin-DeptForm", res.Data);
                    //form.render("select");
                    //下拉树（所属机构）,必须放到设置值以后，不然修改时设置不稳定
                    //treeselect.render(
                    //    {
                    //        elem: "#NF-PDept",
                    //        data: '/System/Department/GetTreeDept',
                    //        method: "GET"
                    //    });
                    if (res.Data.IsMain==1) {
                        $("input[name=IsMain]").attr("checked", true);
                        $("div .deptMain").show();
                      

                    } else {
                        $(".ismain").addClass("layui-hide");
                    }
                    if (res.Data.IsSubCompany==1) {

                        $("input[name=IsSubCompany]").attr("checked", true);
                    }

                }
                });



            }
            //-------------------------------------显示end--------------------------------------------
            form.render(null, 'Nf-SystemAdmin-DeptForm');
            //目录
            //nfcontents.render({
            //    content:'#deptnva'
            //});


    });
        </script>

