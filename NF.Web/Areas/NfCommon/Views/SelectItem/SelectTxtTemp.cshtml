
@{
    ViewData["Title"] = "选择合同模板";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="layui-fluid">
    <input type="hidden" name="hide_keyWord" />
    @*弹框索引，别动*@
    <input type="hidden" name="currIndex" id="currIndex" />
    <div class="layui-card">
        <div class="layui-card-body">
            <table id="NF-SelTxtTemp-Index" lay-filter="NF-SelTxtTemp-Index"></table>
            <!--表格工具栏-->
            <script id="toolcontract" type="text/html">
                <div class="layui-inline">
                    <input class="layui-input" type="text" name="keyWord" placeholder="名称" style="width:260px;" />
                </div>
                <div class="layui-inline">
                    <button class="layui-btn" lay-event="search">
                        <i class="layui-icon layui-icon-search layuiadmin-button-btn"></i>
                    </button>
                </div>
            </script>

        </div>
    </div>
</div>
@{
    Html.RenderPartial("_LayuiScriptsPartial");
   
}

<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index', //主入口模块
        selContTxtTemp: 'common-nf/selectTxtTemp'
    }).use(['index','selContTxtTemp'], function () {
     });
</script>

