
@{
    ViewData["Title"] = "进度任务列表";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="layui-fluid">
    <!--基本信息begin-->
    <div class="layui-form" lay-filter="NF-ScheduleListForm">
        <!--修改时使用-->
        <input type="hidden" id="Id" name="Id" />
        <input type="hidden" id="ScheduleId" name="ScheduleId" />
        <div class="layui-card ">
            <div class="layui-card-header">基本信息</div>
            <div class="layui-card-body" style="padding: 15px;">
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">任务名称</label>
                        <div class="layui-input-block">
                            <input type="text" name="ScheduleName" id="ScheduleName" lay-verify="required" placeholder="请输入" class="layui-input pen" />
                        </div>
                    </div>
                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">任务归属</label>
                        <div class="layui-input-block">
                            <select name="ScheduleAttribution" id="ScheduleAttribution" lay-verify="required" readonly="readonly" lay-search lay-filter="ScheduleAttribution">
                                <option value="">请选择..</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">进度对象</label>
                        <div class="layui-input-block">
                            <input type="text" name="ScheduleDuixiangName" id="ScheduleDuixiangName" class="layui-input" />
                            <input type="hidden" name="ScheduleDuixiang" id="ScheduleDuixiang" />
                        </div>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">任务定义</label>
                        <div class="layui-input-block">
                            <textarea name="Description" class="layui-textarea"></textarea>
                        </div>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">任务描述</label>
                        <div class="layui-input-block">
                            <textarea name="Descriptionms" class="layui-textarea"></textarea>
                        </div>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">提醒人</label>
                        <div class="layui-input-block">
                            <input type="text" name="TixingName" id="TixingName" readonly="readonly" lay-verify="required" class="layui-input pen" />
                            <input type="hidden" name="Tixing" id="Tixing" />
                        </div>
                    </div>
                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">执行人</label>
                        <div class="layui-input-block">
                            <input type="text" name="DesigneeName" id="DesigneeName" readonly="readonly" lay-verify="required" class="layui-input pen" />
                            <input type="hidden" name="Designee" id="Designee" />
                        </div>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">

                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">跟踪者</label>
                        <div class="layui-input-block">
                            <input type="text" name="StalkerName" id="StalkerName" readonly="readonly" lay-verify="required" class="layui-input pen" />
                            <input type="hidden" name="Stalker" id="Stalker" />
                        </div>
                    </div>
                </div>
                <!--需要在最后加这个或者没有也加一个 <div class="layui-form-item">，这样不会导致隐藏菜单是显示问题-->
                <div class="layui-form-item">

                </div>
            </div>
        </div>

        <div class="layui-form-item layui-layout-admin layui-hide">
            <div class="layui-input-block">
                <div class="layui-footer" style="left: 0;">
                    <button class="layui-btn" id="NF-ScheduleList-FormSubmit" lay-submit lay-filter="NF-ScheduleList-FormSubmit">保存</button>
                    <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                </div>
            </div>
        </div>

    </div>
</div>
@{
    Html.RenderPartial("_LayuiScriptsPartial");
}
<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index', //主入口模块
        nfcontents: 'contents-nf/nfcontents',
        commonnf: 'common-nf/commonnf',
        tableSelect: 'layui-nf-plugs/tableSelect',
        selectnfitem: 'common-nf/selectnfitem',
        ScheduleBuild: 'Schedule-nf/Schedule-build',
        treeSelect: 'layui-nf-plugs/treeselect',
        // subMetBuild:'subjectmatter-nf/submet-build',
        wordAddin: 'addin-nf/wordAddin'
    }).use(['index', 'ScheduleBuild', 'commonnf', 'upload'], function () {
        var $ = layui.$
            , admin = layui.admin
            , form = layui.form
            , commonnf = layui.commonnf
            , upload = layui.upload
            , setter = layui.setter;
        var _objId = wooutil.getQueryString('Id');
             /**
        *修改绑定数据
       **/
        if (_objId !== "" && _objId !== undefined && _objId !== 0) {
               admin.req({
                   url: '/schedule/ScheduleList/showview',
                   data: { id: _objId, rand: wooutil.getRandom()},
                   done: function (res) {
                       form.val('NF-ScheduleListForm', res.Data);
                   }
               });
        };
    });
</script>




