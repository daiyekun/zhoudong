
@{
    ViewData["Title"] = "InitData";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="page">
    <div class="page__hd">
        <p class="page__desc">安装以后系统初始化</p>
    </div>
    <div class="page__bd">
        <div class="button-sp-area">
            <a href="javascript:" class="weui-btn weui-btn_primary" id="initMenus">初始化菜单</a>
        </div>
        <div>
            @{
                for (var i = 0; i < 200; i++)
                {
                    <div><a class="icon icon-@i f-red"></a>----ico-@i</div>
                }
            }

        </div>
    </div>
</div>
<script type="text/javascript">
    $("#initMenus").click(function () {
        $.ajax({
            type: 'POST',
            url: '/Home/InitMenus',
            async: false,
            dataType: 'json',
            data: {


            },
            success: function (data) {
                alert(JSON.stringify(data));

            }
        });

    });
</script>


