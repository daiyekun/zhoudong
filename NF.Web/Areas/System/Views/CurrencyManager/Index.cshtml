
@{
    ViewData["Title"] = "币种";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="layui-fluid">
    <input type="hidden" name="hide_keyWord" />
    <div class="layui-card">
        <div class="layui-card-body">
            <table id="NF-CurrencyManager-index" lay-filter="NF-CurrencyManager-index"></table>

            <!--表格工具栏-->
            <script id="toolCurrencyManager" type="text/html">
                <div class="layui-inline">
                    <input class="layui-input" type="text" name="keyWord" placeholder="名称、编号" style="width:240px;" autocomplete="off" />

                </div>
                <div class="layui-inline">
                    <button class="layui-btn" lay-event="search">
                        <i class="layui-icon layui-icon-search layuiadmin-button-btn"></i>
                    </button>
                    <button class="layui-btn" lay-event="add">
                        <i class="layui-icon layui-icon-edit layuiadmin-button-btn">
                        </i>新增
                    </button>
                    <button class="layui-btn" lay-event="batchdel">
                        <i class="layui-icon layui-icon-delete layuiadmin-button-btn"></i>批量删除
                    </button>

                </div>
            </script>

            @*操作*@
            <script type="text/html" id="table-CurrencyManager-bar">
                <a class="layui-btn layui-btn-normal layui-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i>修改</a>
                <a class="layui-btn layui-btn-danger layui-btn-xs" lay-event="del"><i class="layui-icon layui-icon-delete"></i>删除</a>
            </script>

        </div>
    </div>
</div>
@{
   
    Html.RenderPartial("_LayuiScriptsPartial");
}
<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index', //主入口模块
        currencymanagerIndex: 'system-nf/nf-currencymanager-index'

    }).use(['index', 'table', 'currencymanagerIndex'], function () {

     });
</script>


