
@{
    ViewData["Title"] = "合同文本盖章-显示页面";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="layui-fluid">
    <!--基本信息begin-->
    <div class="layui-form" lay-filter="NF-ContTextSealForm">
        @*当前ID*@
        <input type="hidden" id="Id" name="Id" />
        @*修改时合同文本ID*@
        <input type="hidden" id="ContTextId" name="ContTextId" />

        <div class="layui-card ">
            <div class="layui-card-header">基本信息</div>
            <div class="layui-card-body" style="padding: 15px;">
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">签约主体</label>
                        <div class="layui-input-block">
                            <input type="text" name="MainDeptName" readonly class="layui-input detail" />
                        </div>

                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">经办机构</label>
                        <div class="layui-input-block">
                            <input type="text" name="DeptName" readonly class="layui-input detail" />
                        </div>
                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">用章人</label>
                        <div class="layui-input-block">
                            <input type="text" name="CreateUserName" readonly class="layui-input detail" />
                        </div>
                    </div>


                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">用章日期</label>
                        <div class="layui-input-block">
                            <input type="text" name="CreateDateTime" readonly class="layui-input detail" />
                        </div>

                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">合同状态</label>
                        <div class="layui-input-block">
                            <input type="text" name="ContStateDic" readonly class="layui-input detail" />
                        </div>
                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">印章名称</label>
                        <div class="layui-input-block">
                            <input type="text" name="SealName" readonly class="layui-input detail" />
                           
                        </div>
                    </div>


                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">申请人</label>
                        <div class="layui-input-block">
                            <input type="text" name="SealUser" readonly class="layui-input detail" />
                        </div>

                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">用章状态</label>

                        <div class="layui-input-block">
                            <input type="text" name="SealStateDic" readonly class="layui-input detail" />
                        </div>

                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">盖章份数</label>
                        <div class="layui-input-block">
                            <input type="number" name="SealNumber" readonly class="layui-input detail" />
                        </div>
                    </div>
                </div>
      
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">每份盖章数</label>
                        <div class="layui-input-block">
                            <input type="number" name="EachNumber"  readonly class="layui-input detail" />
                        </div>

                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">盖章总数</label>
                        <div class="layui-input-block">
                            <input type="number" name="SealTotal" readonly class="layui-input detail" />
                        </div>
                    </div>



                </div>
                <!--需要在最后加这个或者没有也加一个 <div class="layui-form-item">，这样不会导致隐藏菜单是显示问题-->
                <div class="layui-form-item">
                    
                </div>
            </div>
        </div>

        <div class="layui-form-item layui-layout-admin layui-hide">
            <div class="layui-input-block">
                <div class="layui-footer" style="left: 0;">
                    <button class="layui-btn" id="NF-ContTextSeal-FormSubmit" lay-submit lay-filter="NF-ContTextSeal-FormSubmit">保存</button>
                    <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                </div>
            </div>
        </div>

    </div>
</div>
@{
    Html.RenderPartial("_LayuiScriptsPartial");
}
<script>

    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index',
        commonnf: 'common-nf/commonnf',
    }).use(['index', 'form', 'commonnf', 'upload'], function () {

        var $ = layui.$
            , admin = layui.admin
          , form = layui.form
          , commonnf = layui.commonnf
          , upload = layui.upload
         , setter = layui.setter ;
        var txtId = wooutil.getQueryString('txtId');
        var contId = wooutil.getQueryString('contId');
        $("#ContTextId").val(txtId);
        
         wooutil.showView({
            objId: txtId,
            url: '/ContractDraft/ContText/SealShowView',
            formFilter: 'NF-ContTextSealForm',
            form: form
         });

    });
</script>

