@{
    ViewData["Title"] = "检测资料";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@*<script src="~/lib/modules/customer/wooupload.js"></script>*@
<style>
    .weui-uploader__file img {
        object-fit: cover;
        width: 100%;
        height: 100%;
    }
</style>

<div class="page">

    <div class="weui-panel__bd page-bd" style="padding-bottom:150px;">
        @*审批事项用于判断是否有审批按钮*@

        @*合同金额*@

        <input type="hidden" id="CompanyId" name="CompanyId" value="@ViewData["CompanyId"]" />
        <input type="hidden" id="CurrWxUserId" name="CurrWxUserId" value="@ViewData["WxCurrUserId"]" />
        <input type="hidden" id="GuidFileName" name="GuidFileName" value="ContAttacFile" />
        <input type="hidden" id="Extension" name="Extension" value="" />
        <input type="hidden" id="FolderName" name="FolderName" value="" />
        <input type="hidden" id="Name" name="Name" value="" />
        <input type="hidden" id="Id" name="Id" value="0" />


        @*基本信息----begin*@
        <div class="weui-panel weui-panel_access">

            <div class="weui-panel__hd">基本信息</div>
            <div class="weui-panel__bd">
                <div class="weui-cell weui-cell_active weui-cell_disabled">
                    <div class="weui-cell__hd"><label class="weui-label">授权码</label></div>
                    <div class="weui-cell__bd">
                        <input class="weui-input" name="QxCode" id="QxCode" placeholder="授权码" type="text">
                    </div>
                </div>
                <div class="weui-cell weui-cell_active weui-cell_disabled">
                    <div class="weui-cell__hd"><label class="weui-label">标题</label></div>
                    <div class="weui-cell__bd">
                        <input class="weui-input" name="Title" id="Title" placeholder="标题" type="text">
                    </div>
                </div>
                <div class="weui-cell weui-cell_active weui-cell_disabled">
                    <div class="weui-cell__hd"><label class="weui-label">客户名称</label></div>
                    <div class="weui-cell__bd">
                        <input class="weui-input" name="CompanyName" id="CompanyName" placeholder="客户名称" type="text">
                    </div>
                </div>
                <div class="weui-cell weui-cell_active weui-cell_disabled">
                    <div class="weui-cell__hd"><label class="weui-label">检测时间</label></div>
                    <div class="weui-cell__bd">
                        <input class="weui-input" name="TxDate" id="TxDate" placeholder="请输入检测时间" type="date">
                    </div>
                </div>

                <div class="weui-cell">
                    <div class="weui-cell__bd">
                        <textarea class="weui-textarea" name="Remark" id="Remark" placeholder="请输入描述" rows="4" onkeyup="textarea(this);"></textarea>
                        <div class="weui-textarea-counter"><span>0</span>/<i>1000</i></div>
                    </div>
                    <i class="weui-icon-clear" onclick="cleararea(this)"></i>
                </div>


                <div class="weui-uploader">
                    <div class="weui-uploader__hd">
                        <p class="weui-uploader__title">上传图片</p>
                        <div class="weui-uploader__info">0/9</div>
                    </div>

                    <div class="weui-uploader__bd">
                        <ul class="weui-uploader__files" id="uploaderFiles">
                        </ul>
                        <div class="weui-uploader__input-box">
                            <input id="uploaderInput" class="weui-uploader__input" accept="image/*" multiple="" type="file" onchange="uploadimgs(this)">
                        </div>
                    </div>

                    <script>
                        function previewImage(file) {
                            var MAXWIDTH = 1000;
                            var MAXHEIGHT = 1200;
                            if (file.files && file.files[0]) {
                                var reader = new FileReader();
                                reader.onload = function (evt) {

                                    $.post("/NfCommon/WxCheckFile/WxUpload1",{imgbase64: evt.target.result},function(rs){

                                            $("#GuidFileName").val(rs.Data.GuidFileName);
                                            $("#Extension").val(rs.Data.Extension);
                                            $("#FolderName").val(rs.Data.FolderName)
                                           var pgsrc="/Uploads/"+rs.Data.SourceFileName;
                                        $(file).parent().prev().html('<li  onclick="removeimg(this)" class="weui-uploader__file" style="background-image:url('+evt.target.result+')"><input value="'+pgsrc+'"  type="hidden"  name="files" /></li>');
                                    },'json');
                                };


                                reader.readAsDataURL(file.files[0]);
                                $("#Name").val(file.files[0].name);
                               // console.log(file.files[0]);
                            }
                        }
                    </script>

                    <script>

                        //多图片上传
                          function removeimgs(obj){
                              $.confirm('您确定要删除吗?', '确认删除?', function() {
                                var delId=$(obj).children("input[name=files]").val();
                                  $.get("/NfCommon/WxCheckFile/DeleteData", {Id: delId}, function (rs) {
                                         $(obj).remove();
                                      }, 'json');

                              });
                              return false;
                          }
                          function uploadimgs(obj) {
                              var files = obj.files;
                              var len = files.length;
                              var $commpId=$("#CompanyId").val();//客户ID
                              for (var i=0; i < len; i++) {
                                  lrz(files[i], {width: 750, fieldName: "file"}).then(function (data) {
                                      $.post("/NfCommon/WxCheckFile/WxUpload1s", {imgbase64: data.base64,commpId:$commpId}, function (rs) {

                                            var pgsrc=rs.Data.FilePath;
                                            var tpId=rs.Data.Id;//添加数据库ID
                                          $(obj).parent().prev().append('<li onclick="removeimgs(this)" class="weui-uploader__file " style="background-image:url(' + pgsrc + ')"><input value="'+tpId+'"  type="hidden"  name="files" /></li>');
                                      }, 'json');

                                  }).then(function (data) {

                                  }).catch(function (err) {
                                      console.log(err);
                                  });
                              }
                          }




                    </script>

                </div>
            </div>

      
            <div class="weui-cell__bd">
                <div class="weui-uploader">
                    <div class="weui-uploader__hd">
                        <p class="weui-uploader__title">上传视频</p>
                        <div class="weui-uploader__info">请选择视频文件</div>
                    </div>
                    <div class="weui-uploader__bd">
                        <ul class="weui-uploader__files" id="videoList">
                            <!-- 上传成功后，可以在此处显示已上传的视频信息 -->
                        </ul>
                        <!-- 模板 -->
                        <template id="videoListItemTemplate">
                            <li>
                                <video width="300" height="200" controls poster="" src="" accelerometer></video>
                                <input type="button" value=" 删 除 " id="" onclick="removevideo(this)" />
                            </li>
                        </template>
                        <div class="weui-uploader__input-box">
                            <input id="uploaderInput" class="weui-uploader__input" type="file" accept="video/*" onchange="uploadvideo(this)">
                        </div>
                    </div>
                </div>
            </div>
            @*<div class="weui-cell__ft">
            <button id="submitBtn" class="weui-btn weui-btn_primary">提交</button>
            </div>*@
            <script>

                //多图片上传
                function removevideo(obj) {
                    $.confirm('您确定要删除吗?', '确认删除?', function () {
                        var delId = $(obj).attr("id");
                        $.get("/NfCommon/WxCheckFile/DeleteData", { Id: delId }, function (rs) {
                            $(obj).parent() .remove();
                        }, 'json');

                    });
                    return false;
                }
                function createVideoListItem(video) {
                    const template = document.getElementById('videoListItemTemplate');
                    const clone = template.content.cloneNode(true);

                    const videoItem = clone.querySelector('video');
                    videoItem.src = video.Data.FilePath; //URL.createObjectURL(video);
                    videoItem.poster = video.Data.ThumPath;//videoThumbnailURL; // 这里需要设置视频缩略图的 URL

                    const videoItemBtn2 = clone.querySelector('input');
                    videoItemBtn2.id = video.Data.Id
                    return clone;
                }
                //视频列表
                function addVideoToList(video) {
                    const videoList = document.getElementById('videoList');
                    const videoListItem = createVideoListItem(video);
                    videoList.appendChild(videoListItem);
                }
                //上传视频
                function savevideoinfo(res) {
                    //debugger;
                    var $commpId = $("#CompanyId").val();
                    var resdata=res.Data;
                    resdata.CompanyId = $commpId;
                    var poststr = JSON.stringify(resdata);
                    var $url = woowx.constant.APIBaseURL + "/NfCommon/WxCheckFile/AddVedioInfo";
                    $.ajax({
                        type: 'POST',
                        url: $url,
                        data: poststr,
                        dataType: 'json',
                        contentType: 'application/json;charset=UTF-8',
                        timeout: 10000,
                        success: function (data) {

                        }, error: function (xhr, type) {
                            var errmsg = "错误类型：" + type + ",xhr.status:" + xhr.status


                        }
                    });
                }
                function uploadvideo(obj) {

                    var files = obj.files;
                    var len = files.length;
                    var $commpId = $("#CompanyId").val();//客户ID
                    for (var i = 0; i < len; i++) {

                        //alert("for==" + i);

                    //var fileInput = document.getElementById('uploaderInput');
                    var file = files[i];
                    var formData = new FormData();
                    formData.append('video', file);
                    formData.append('imgbase64', 'upload.mp4');
                    formData.append('commpId', $commpId);
                      $.showLoading("上传视频中,等待.");
                    $.ajax({
                        //url: '/NfCommon/WxFile/WxUploadvideo
                            url: '/NfCommon/WxCheckFile/UploadVideoMax',
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function (res) {
                            //alert(JSON.stringify(res));
                            console.log(res);
                            addVideoToList(res);
                                savevideoinfo(res);
                             $.hideLoading();

                        },
                        error: function (xhr, status, error) {
                                alert("错误消息="+error + status);
                               $.hideLoading();
                               console.log(error);

                        }
                    });

                    }



                }
            </script>

            @*视频*@

            @*视频*@


        </div>

    </div>
    @*基本信息----end*@
    <div class="weui-footer weui-footer_fixed-bottom" style="padding-bottom:50px;">
        <a href="javascript:;" onclick="savecustomerFw()" class="weui-btn bg-green"><i class="icon icon-103" id="savecustomerFw"></i>保存</a>
    </div>

    <div class="weui-footer weui-footer_fixed-bottom">
    </div>

</div>


<script type="text/javascript">
    function textarea(input) {
            var content = $(input);
              var max =  content.next().find('i') .text();
            var value = content.val();
            if (value.length>0) {

                value = value.replace(/\n|\r/gi,"");
                var len = value.length;
                content.next().find('span').text(len) ;
                 if(len>max){
                     content.next().addClass('f-red');
                 }else{
                     content.next().removeClass('f-red');
                 }
            }
        }

        function cleartxt(obj){
            $(obj).prev().find('.weui-input').val("");
            return false;
        }

        function cleararea(obj){
            $(obj).prev().find('.weui-textarea').val("").next().find("span").text(0);
            return false;
        }


        //保存
         function savecustomerFw(){
           // $.toast("我是文本",'text');
             var otion = {
            Id: $("#Id").val(),//Id
            WxCode:$("#CurrWxUserId").val(),//微信账号
            // GuidFileName: $("#GuidFileName").val(),
            // FolderName: $("#FolderName").val(),
            Title: $("#Title").val(),
            CompanyName: $("#CompanyName").val(),
            Remark: $("#Remark").val(),
            QxCode: $("#QxCode").val(),
            TxDate: $("#TxDate").val()

        };


         var poststr = JSON.stringify(otion);
         var $url = woowx.constant.APIBaseURL + "/api/Check/CheckAddSave";
               $.ajax({
            type: 'POST',
            url: $url,
            data: poststr,
            dataType: 'json',
            contentType: 'application/json;charset=UTF-8',
            timeout: 10000,
            success: function (data) {
                var $data = JSON.parse(data);
                if ($data.Code === 0) {

                    window.location.href = "/Common/SuccMag";



                } else {
                    window.location.href = "/Common/FailMsg";
                }
            }, error: function (xhr, type) {
                var errmsg = "错误类型：" + type + ",xhr.status:" + xhr.status
                window.location.href = "/Common/FailMsg?errmsg=" + errmsg;

            }
        });
        }

</script>
