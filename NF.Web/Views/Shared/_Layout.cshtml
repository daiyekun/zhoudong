<!DOCTYPE html>
<html xmlns:v="urn:schemas-microsoft-com:vml">
<head>
    <meta charset="utf-8">
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title></title>
    <link href="~/lib/layuiadmin/layui/css/layui.css" rel="stylesheet" media="all" />
    <link href="~/lib/layuiadmin/style/admin.css" rel="stylesheet" media="all" />
   
    @*自己定义的样式*@
    <link href="~/css/nfcommon.css" rel="stylesheet" media="all" />
    <script>
        /^http(s*):\/\//.test(location.href) || alert('请先部署到 localhost 下再访问');
    </script>
    @*专门将5个字改成容纳7个字问题*@
    <style>
        .layui-form-label {
            width: 100px;
        }

        .layui-input-block {
            margin-left: 130px;
        }
    </style>
</head>
<body>
    <div class="layui-layout-body">
        @RenderBody()

    </div>
    @RenderSection("Scripts", required: false)

  
    
</body>
</html>

