
@{
    ViewData["Title"] = "模板新建";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/lib/layuiadmin/modules/layui-nf-plugs/formSelects/formSelects-v4.css" />
<div class="layui-fluid">
    <!--基本信息begin-->
    <div class="layui-form" lay-filter="NF-ContTxtTemp-BuildForm">
        <!--修改时使用-->
        <input type="hidden" id="Id" name="Id" value="0" />
        @*模板历史ID*@
        <input type="hidden" id="HistId" name="HistId" value="0" />
        @*版本*@
        <input type="hidden" id="Vesion" name="Vesion" />
        @*选择格式*@
        <input type="hidden" id="FieldTypeVal" name="FieldTypeVal" value="0" />
        @*选择业务品类ID*@
        <input type="hidden" id="SelBcId" name="SelBcId" value="0" />
        @*//是否显示标的*@
        <input type="hidden" id="ShowSub" name="ShowSub" value="0" />

        <div class="layui-card " id="Info">
            <div class="layui-card-header">基本信息</div>
            <div class="layui-card-body" style="padding: 15px;">
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">模板名称</label>
                        <div class="layui-input-block">
                            <input type="text" name="Name" lay-verify="required" placeholder="请输入" autocomplete="off" class="layui-input pen" />
                        </div>
                    </div>
                    <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">模板类别</label>
                        <div class="layui-input-block">
                            <select name="TepTypes" xm-select="TepTypes" lay-verify="required" xm-select-skin="normal">
                                <option value="-1">请选择</option>
                            </select>
                          
                        </div>
                    </div>
                </div>

                <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                    <label class="layui-form-label">所属机构</label>
                    <div class="layui-input-block">
                        <select name="DeptIds" xm-select="DeptIds" lay-verify="required" xm-select-skin="normal">
                            <option value="-1">请选择</option>
                        </select>
                    </div>
                </div>
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12">
                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">文本类别</label>
                        <div class="layui-input-block">
                            <select name="TextType" id="TextType" lay-verify="required" lay-search lay-filter="ContTypeId">
                                <option value="">请选择..</option>

                            </select>
                        </div>
                    </div>
                    <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">模板状态</label>
                        <div class="layui-input-block">
                            <input type="radio" name="Tstate" value="1" title="启用" checked>
                            <input type="radio" name="Tstate" value="0" title="禁用">
                        </div>
                    </div>

                </div>
                <div class="layui-col-lg6 layui-col-md6 layui-col-xs12 layui-col-sm12">
                    <div class="layui-input-block">
                        <input type="checkbox" name="ShowSubMatter" id="ShowSubMatter" lay-filter="ShowSubMatter" lay-skin="primary" title="标的设置(可选)如合同文本中包含合同标的">
                    </div>
                </div>

                <!--需要在最后加这个或者没有也加一个 <div class="layui-form-item">，这样不会导致隐藏菜单是显示问题-->
                <div class="layui-form-item">

                </div>

            </div>
        </div>
        <div class="layui-card layui-hide" id="BiaoDi">
            <div class="layui-card-body" style="padding: 15px;">
                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12 ">
                    <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">明细标题</label>
                        <div class="layui-input-block">
                            <input type="text" name="MingXiTitle" class="layui-input" />
                        </div>
                    </div>
                </div>

                <div class="layui-row layui-col-space10 layui-form-item layui-col-lg12 ">
                    <div class="layui-col-lg12 layui-col-md12 layui-col-xs12 layui-col-sm12">
                        <label class="layui-form-label">显示格式</label>
                        <div class="layui-input-block">
                            <input type="radio" name="FieldType" lay-filter="FieldType" value="0" title="合同标的统一格式" checked>
                            <input type="radio" name="FieldType" lay-filter="FieldType" value="1" title="按业务品类设置格式">
                        </div>
                    </div>
                </div>
                <fieldset class="layui-elem-field layui-field-title" style="margin-top: 30px;">
                    <legend style="color:#FF5722">标的模板字段</legend>
                </fieldset>
                @*标的模板begin*@
                <div class="layui-row layui-col-space5">
                    <div class="layui-col-xs6 layui-col-sm5 layui-col-md3 layui-hide bcCategory">
                        <div class="layui-card" id="bcCategory">
                            <div class="layui-card-header">业务类别:<span id="selCateName" style="color:#FF5722"></span></div>
                            <div class="layui-card-body">
                                @*选择类别*@
                                <div id="BcCategory_Tree" style="width: 100%; height:350px; overflow:auto;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="layui-col-xs6 layui-col-sm7 layui-col-md9">
                        <div class="layui-card">
                            <div class="layui-card-body">
                                <table id="NF-ContSubFildTemp" lay-filter="NF-ContSubFildTemp"></table>
                                <script type="text/html" id="toolbarSubFiled">
                                    <div class="layui-btn-container">
                                        <button class="layui-btn layui-btn-sm" lay-event="add">添加</button>
                                        <button class="layui-btn layui-btn-sm" lay-event="saveAll">保存</button>
                                    </div>
                                </script>

                                <script type="text/html" id="subFiledTool">
                                    <a class="layui-btn layui-btn-normal layui-btn-xs" lay-event="up"><i class="layui-icon layui-icon-up"></i>上移</a>
                                    <a class="layui-btn layui-btn-normal layui-btn-xs" lay-event="down"><i class="layui-icon layui-icon-down"></i>下移</a>
                                    <a class="layui-btn layui-btn-danger layui-btn-xs" lay-event="del"><i class="layui-icon layui-icon-delete"></i>删除</a>
                                </script>
                            </div>
                        </div>
                    </div>
                </div>
                @*标的模板end*@

            </div>
        </div>



        <!--按钮begin-->
        <div class="layui-form-item layui-layout-admin layui-hide">
            <div class="layui-input-block">
                <div class="layui-footer" style="left: 0;">
                    <button class="layui-btn" id="NF-ContTxtTemp-FormSubmit" lay-submit lay-filter="NF-ContTxtTemp-FormSubmit">保存</button>
                    <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                </div>
            </div>
        </div>
        <!--按钮begin-->
    </div>
</div>
@{
    Html.RenderPartial("_LayuiScriptsPartial");
}
<script>

    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
        index: 'lib/index', //主入口模块
        commonnf: 'common-nf/commonnf'
         , formSelects: 'layui-nf-plugs/formSelects/formSelects-v4'
         , contTxtTempBuild: 'conttxttemp-nf/conttxttemp-build'
         , checkbox: 'layui-nf-plugs/checkboxsel/checkbox'
    }).use(['index', 'contTxtTempBuild'], function () {
        wooutil.selpen();

    });
</script>