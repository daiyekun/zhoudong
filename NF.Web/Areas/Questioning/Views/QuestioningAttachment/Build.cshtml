                        @*<div class="layui-input-block">*@
                        <div class="layui-input-inline" style="width:70%;">
                            <input type="text" name="FileName" lay-verify="required" placeholder="иѓЈиЊУеЕ•" autocomplete="off" class="layui-input pen" />
                        </div>
                        <div class="layui-form-mid layui-word-aux" style="margin-top:-9px;">
                            <button class="layui-btn layui-btn layui-btn-sm " id="contract-attUpload" style="height:38px;line-height:38px;">жµПиІИ</button>
                        </div>
                    </div>
                    <div class="layui-col-lg4 layui-col-md4 layui-col-xs12 layui-col-sm12">
