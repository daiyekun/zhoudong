@{
    ViewData["Title"] = "系统提醒列表";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="layui-fluid">
    <div class="layui-card">
        <div class="layui-card-body">
            <table id="NF-remind-index" lay-filter="NF-remind-index"></table>
            <!--查看详情-->
            <script type="text/html" id="nameTpl">
                <a class="layui-table-link hand" lay-text="查看详情" lay-event="detail">
                    <cite>{{d.Name}}</cite>
                </a>
            </script>
            <!--表格工具栏-->
            <script id="toolremind" type="text/html">
                <div class="layui-inline">
                    <input class="layui-input" type="text" name="keyWord" placeholder="提醒事项、提醒描述" style="width:240px;" autocomplete="off" />

                </div>
                <div class="layui-inline">
                    <button class="layui-btn" lay-event="search">
                        <i class="layui-icon layui-icon-search layuiadmin-button-btn"></i>
                    </button>

                    @*<button class="layui-btn" lay-event="batchdel">
                        <i class="layui-icon layui-icon-delete layuiadmin-button-btn"></i>批量删除
                    </button>*@
                    <button class="layui-btn layui-btn-normal" lay-event="save">
                        <i class="layui-icon  "></i>保存
                    </button>
                </div>

            </script>





        </div>
    </div>
</div>
@{
    Html.RenderPartial("_LayuiScriptsPartial");
}

<script>
    layui.config({
        base: '/lib/layuiadmin/'
    }).extend({
       index: 'lib/index'

    }).use(['index', 'table', 'form'], function () {
        var $ = layui.$
  , table = layui.table
  , setter = layui.setter
  , admin = layui.admin
  , form = layui.form;
   var postData = [];//保存时提交数据

  var logdindex = layer.load(0, { shade: false });
        //提醒列表
        table.render({
            elem: '#NF-remind-index'
           , url: '/System/Remind/GetList?rand=' + wooutil.getRandom()
           , toolbar: '#toolremind'
           , defaultToolbar: ['filter']
           , cellMinWidth: 100
           , cols: [[
                 { type: 'numbers', fixed: 'left' }
               , { type: 'checkbox', fixed: 'left' }
               , { field: 'Name', title: '提醒事项', width: 260, fixed: 'left' }
               , { field: 'CustomName', title: '提醒描述', width: 350, edit: 'text' }
               , { field: 'AheadDays', title: '提前天数', width: 140, edit: 'text' }
               , { field: 'DelayDays', title: '延后天数', width: 140, edit: 'text' }
               , { field: 'Id', title: 'Id', width: 80, hide: true }

           ]]
           //, page: true
           , loading: true
           , height: setter.table.height_4
           , limit: setter.table.limit
           , limits: setter.table.limits
           , done: function (res, curr, count) {
               layer.close(logdindex);

           }
        });

        var active = {
            search: function () {//查询
                table.reload('NF-remind-index', {
                    page: { curr: 1 }
                    , where: {
                        keyWord: $("input[name=keyWord]").val()

                    }
                });
            },
            batchdel: function () {//删除
                wooutil.deleteDatas({ tableId: 'NF-remind-index', table: table, url: '/System/Remind/Delete' });
            },
            save: function () {
                if (postData.length == 0) {
                   return layer.alert("当前没有数据进行修改！");
                }else{
                admin.req({
                    url: '/System/Remind/SaveData',
                    data: { data: postData },
                    type: 'POST',
                    success: function (res) {
                       
                        if (res.RetValue==1) {
                            postData = [];
                            layer.msg("保存成功！", { icon: 1, time: 500 }, function (msgindex) {
                                table.reload("NF-remind-index", {
                                    where: { rand: wooutil.getRandom() }

                                });

                            });
                        } else {
                            postData = [];
                            layer.msg("保存失败提前天数和延后天数请分开保存！", { icon: 5, time: 500 }, function (msgindex) {
                                table.reload("NF-remind-index", {
                                    where: { rand: wooutil.getRandom() }

                                });

                            });
                         
                           
                        }

                      
                    }
                });

               
                }
            }
        };
        /***
        *工具栏
        ***/
        table.on('toolbar(NF-remind-index)', function (obj)
        {
            switch (obj.event) {
                case 'search':
                    active.search();
                    break;
                case "batchdel":
                    active.batchdel();
                    break;
                case "save":
                    active.save();
                    break;
            }

        });
        /**监听单元格编辑***/
        table.on('edit(NF-remind-index)', function (obj) {
            var $data = obj.data;//编辑行的值
            
             postData.push($data);

        });


     });
</script>


