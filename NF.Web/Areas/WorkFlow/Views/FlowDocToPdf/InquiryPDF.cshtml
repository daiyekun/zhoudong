@model NF.ViewModel.Models.InquiryInfo
@{
    Layout = null;
}
<style>
    table {
        border-top: 1px solid #000000;
        border-left: 1px solid #000000;
        border-collapse: collapse; /*设置单元格的边框合并为1*/
        line-height: 40px; /*设置行高*/
    }

    td {
        border-bottom: 1px solid #000000;
        border-right: 1px solid #000000;
    }



    /**字体颜色和背景**/
    /***
      table tr:nth-child(odd) {
          background: #F4F4F4;
      }
      table tr:nth-child(even) {
          color: #C00;
      }
    ****/
</style>
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>询价审批单</title>
</head>
<body>
    <table width="100%">
        <tr>
            <td align="center">
                <b>
                    询价审批单
                </b>
            </td>
        </tr>
    </table>
    <table width="100%">
        <tr>
            <td align="center">
                记录人
            </td>
            <td colspan="3">
                @Model.RecorderName
            </td>

        </tr>
        <tr>

            <td align="center">
                时间
            </td>
            <td>@Model.Times</td>
            <td align="center">
                项目编号
            </td>
            <td>@Model.ProjectNumber</td>
        </tr>
        <tr>
            <td align="center">
                地点
            </td>
            <td>@Model.Sites</td>
            <td align="center">
                创建人
            </td>
            <td>@Model.CreateName</td>
        </tr>
        <tr>
            <td align="center">
                中标条件
            </td>
            <td>@Model.TheWinningConditions</td>
            <td align="center">
               有效期
            </td>
            <td>@Model.UsefulLife</td>
        </tr>

    </table>

    <table width="100%">
        <tr>
            <td align="center">
                节点名称
            </td>
            <td align="center">
                用户名
            </td>
            <td align="center">
                审批意见
            </td>
            <td align="center">
                审批时间
            </td>
        </tr>
        @foreach (var key in Model.DicWfData.Keys)
        {
            int rowindex = 0;
            @foreach (var item in Model.DicWfData[key])
            {

                <tr>
                    @if (rowindex == 0)
                    {
                        <td style="text-align:center; width:22%" rowspan="@Model.DicWfData[key].Count()">
                            @key
                        </td>
                    }
                <td style="width:15%" align="center">
                    @if (@item.UserEs == "1" && @item.UserEsTy == "1")
                    {
                        <img src="@item.ImgSrc">
                    }
                    else
                    {
                        @item.AppUserName
                    }
                </td>
                    <td style="width:48%">
                        @item.Option
                    </td>

                    <td style="width:15%;text-align:center;">
                        @item.AppDate
                    </td>
                </tr>
                rowindex++;
            }


        }

    </table>
    <div style="text-align:right;">生成日期： @DateTime.Now.ToString("yyyy-MM-dd")</div>
</body>
</html>